#!/usr/bin/env nu

let CSV_PATH = $"($env.HOME)/.local/state/terminal-sessions.csv"
const PLUGIN_LOCATION = "file:~/dev/clone/zestty/target/wasm32-wasip1/release/zestty.wasm"
const DEFAULT_LAYOUT = "compact"

# Autocomplete function for project directories
def get-project-dirs []: nothing -> list<string> {
    let all_dirs = (
        (do -i { ls ~/dev/alt/* ~/dev/clone/* ~/dev/github/* ~/dev/gitlab/* ~/dev/wl/* | get name })
        | append (do -i { ls ~/notes/* | where type == dir | get name })
        | append (do -i { ls $"/run/media/($env.USER)/*" | get name })
    )
    $all_dirs
}

# Get all active and dead Zellij sessions with their state
# Returns a list of records with name and state
def get-zellij-sessions [] {
    zellij list-sessions --no-formatting
    | lines
    | each { |line|
        let is_dead = ($line | str contains "(EXITED - attach to resurrect)")
        let name = ($line | split row " " | first)
        { name: $name, state: (if $is_dead { "dead" } else { "active" }) }
    }
}

# Initialize CSV file if it doesn't exist, returns csv data
def get-csv-data [] {
    if not ($CSV_PATH | path exists) {
        "path,name,keybind,layout\n" | save $CSV_PATH
    }
    open --raw $CSV_PATH | from csv
}

def is-inside-zellij [] {
    if ($env.ZELLIJ? | default "1") == "1" {
        print -e $"(ansi red)Must be in a zellij session!(ansi reset)"
        exit 1
    }
}

# Write bindings to CSV
def write-csv [data: table] {
    $data | to csv | save -f $CSV_PATH
}

def zestty-call-plugin [payload: string, session?: string] {
    let session_name = if $session != null {
        $session
    } else {
        $env.ZELLIJ_SESSION_NAME? | default ""
    }
    
    let session_opt = if ($session_name | is-not-empty) {
        ["--session", $session_name]
    } else {
        []
    }
    
    zellij ...$session_opt pipe --plugin $PLUGIN_LOCATION --plugin-configuration $"default_layout=($DEFAULT_LAYOUT)" -- $payload
}

def zestty-call-add-session-to-cycle [name: string] {
    if ($name | is-empty) {
        return
    }
    
    # Background process to add session to cycle
    nu -c $'
        sleep 1sec
        zellij --session ($name) pipe --plugin ($PLUGIN_LOCATION) --plugin-configuration "default_layout=($DEFAULT_LAYOUT)" -- "{ \"command\": \"add-session-to-cycle\" }"
    ' | ignore
}

def zestty-call-switch-session [name: string, path?: string, layout?: string] {
    if ($name | is-empty) {
        exit-fail "Session name required!"
    }
    
    mut options = $"{ \"command\": \"switch-session\", \"name\": \"($name)\""
    
    if $path != null and ($path | path exists) and ($path | path type) == "dir" {
        $options = $options + $", \"path\": \"($path)\""
    }
    
    if $layout != null and ($layout | is-not-empty) {
        $options = $options + $", \"layout\": \"($layout)\""
    }
    
    $options = $options + " }"
    zestty-call-plugin $options
}

# Build the global session list by merging csv, zellij sessions, and project dirs
def global-session-list [] {
    mut csv_data = get-csv-data
    let zellij_sessions = get-zellij-sessions
    let project_dirs = get-project-dirs

    # Auto-add active/dead zellij sessions not in CSV
    let csv_names = ($csv_data | get name)
    let new_from_zellij = (
        $zellij_sessions
        | where { |s| not ($s.name in $csv_names) }
        | each { |s| { path: null, name: $s.name, keybind: null, layout: $DEFAULT_LAYOUT } }
    )
    if not ($new_from_zellij | is-empty) {
        $csv_data  = ($csv_data | append $new_from_zellij)
        write-csv $csv_data
    }

    # Build entries from CSV with state resolved from zellij sessions
    let csv_entries = (
        $csv_data
        | each { |row|
            let zellij_match = ($zellij_sessions | where name == $row.name | get 0?)
            let state = if $zellij_match != null {
                $zellij_match.state
            } else {
                "deleted"
            }
            {
                path: $row.path,
                name: $row.name,
                keybind: $row.keybind,
                layout: $row.layout,
                state: $state
            }
        }
    )

    # Build entries from project dirs not already covered by CSV paths
    let csv_paths = ($csv_data | get path | compact)
    let dir_entries = (
        $project_dirs
        | where { |d| not ($d in $csv_paths) }
        | each { |d|
            {
                path: $d,
                name: null,
                keybind: null,
                layout: $DEFAULT_LAYOUT,
                state: "absent"
            }
        }
    )

    $csv_entries | append $dir_entries
}

# List all sessions (active, dead, deleted, absent)
def "main list" [] {
    global-session-list | where state != "absent" | table -t psql
}

# Attach to a session by name or fuzzy finder
def "main attach" [name?: string] {
    let sessions = global-session-list

    mut entry = if ($name | is-empty) {
        $sessions | input list --fuzzy
    } else {
        mut found = ($sessions | where name == $name | get 0?)
        if $found == null {
            $found = { path: null, name: $name, keybind: null, layout: null, state: "absent" }
        }
        $found
    }

    if $entry == null {
        exit 1
    }

    if $entry.state == "active" or $entry.state == "dead" {
        if ($env.ZELLIJ? | default "1") == "0" {
            zestty-call-switch-session $entry.name $entry.path $entry.layout
        } else {
            zestty-call-add-session-to-cycle $entry.name
            exec zellij attach $entry.name
        }
    } else {
        # Resolve path
        if $entry.path == null {
            $entry.path = (input $"Enter path \(default: ($env.HOME)): " | str trim)
            if ($entry.path | is-empty) {
                $entry.path = $env.HOME
            }
        }

        # Resolve name from basename, prompt to confirm/change
        $entry.name = ($entry.path | path basename)
        let taken_names = ($sessions | get name | uniq)

        loop {
            let name_input = (input $"Enter session name \(default: ($entry.name)): " | str trim)
            if not ($name_input | is-empty) {
                if ($name_input in $taken_names) {
                    print $"Name '($name_input)' is already taken by an active session. Please choose another."
                    continue
                }
                $entry.name = $name_input
            } else {
                break
            }
        }

        # Resolve keybind
        let $keybind_input = (input -n 1 $"Enter keybind \(default: none, press enter to skip): " | str trim)

        # Check keybind conflict
        if not ($keybind_input | is-empty) {
            let existing = ($sessions | where keybind == $keybind_input | get 0?)
            if not ($existing | is-empty) {
                print $"Warning: Key '($existing.keybind)' is already bound to session '($existing.name)'"
                let confirm = (input -n 1 "Override? (y/n): ")
                if $confirm == "y" or $confirm == "Y" {
                    $entry.keybind = $keybind_input
                }
            } else {
                $entry.keybind = $keybind_input
            }
        }

        # Resolve layout
        $entry.layout = (input $"Enter layout \(default: ($DEFAULT_LAYOUT)): " | str trim)
        if ($entry.layout | is-empty) {
            $entry.layout = $DEFAULT_LAYOUT
        }

        # Remove old keybind entry if overriding
        let updated_csv = (get-csv-data | where keybind != $entry.keybind and name != $entry.name | append $entry)
        write-csv $updated_csv

        # Create session
        if ($env.ZELLIJ? | default "1") == "0" {
            zestty-call-switch-session $entry.name $entry.path $entry.layout
        } else {
            zestty-call-add-session-to-cycle $entry.name
            cd $entry.path
            exec zellij --session $entry.name --new-session-with-layout $entry.layout
        }
    }
}

# Switch to a session by keybind
def "main switch" [] {
    let csv_data = get-csv-data
    let key = (input -n 1 "Enter keybind: ")

    let entry = ($csv_data | where keybind == $key | first)

    if ($entry | is-empty) {
        print $"No session bound to key '($key)'"
        return
    }

    zestty-call-switch-session $entry.name $entry.path $entry.layout
}

# Bind current session to a keybind
def "main bind" [] {
    let csv_data = get-csv-data
    is-inside-zellij

    let key = (input -n 1 "Enter keybind: ")

    # Check if keybind already exists
    let existing = ($csv_data | where keybind == $key)

    if not ($existing | is-empty) {
        print $"Warning: Key '($key)' is already bound to session '($existing.name)'"
        let confirm = (input -n 1 "Override? (y/n): ")

        if $confirm != "y" and $confirm != "Y" {
            print "Cancelled"
            return
        }

        # Remove old binding
        let updated = ($csv_data | where keybind != $key)
        write-csv ($updated | append {path: $env.PWD, name: $env.ZELLIJ_SESSION_NAME, keybind: $key, layout: $DEFAULT_LAYOUT})
        print $"Bound session '($env.ZELLIJ_SESSION_NAME)' to key '($key)'"
        return
    }

    let updated = ($csv_data | append {path: $env.PWD, name: $env.ZELLIJ_SESSION_NAME, keybind: $key, layout: $DEFAULT_LAYOUT})
    write-csv $updated

    print $"Bound session '($env.ZELLIJ_SESSION_NAME)' to key '($key)'"
}

# Unbind a session
def "main unbind" [] {
    let csv_data = get-csv-data

    let selected = ($csv_data | input list --fuzzy "Select binding to remove: ")

    if ($selected | is-empty) {
        print "No binding selected"
        return
    }

    # Clear only the keybind field, keep the rest of the record
    let updated = ($csv_data | each { |row|
        if $row.keybind == $selected.keybind {
            $row | upsert keybind ""
        } else {
            $row
        }
    })
    write-csv $updated

    print $"Removed binding for key '($selected.keybind)'"
}

def "main previous" [] {
    is-inside-zellij
    zestty-call-plugin '{"command": "cycle-previous"}'
}

def "main next" [] {
    is-inside-zellij
    zestty-call-plugin '{"command": "cycle-next"}'
}

def "main last" [] {
    is-inside-zellij
    zestty-call-plugin '{"command": "cycle-back"}'
}

# Main entry point
def main [] {
    print $"Zellij Session Manager

(ansi default_bold)Available Commands(ansi reset)
list       List all sessions \(active, dead, deleted, absent)
attach     Pick and attach to a session \(fuzzy finder)
switch     Switch to a session with a keybind
bind       Bind current session to a keybind
unbind     Unbind a session
previous   Cycle to previous session
next       Cycle to next session
last       Cycle back to last session"
}
